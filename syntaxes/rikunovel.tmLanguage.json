{
	"name": "RikuNovel",
	"scopeName": "source.rikunovel",
	"patterns": [
		{
			"include": "#variables"
		},
		{
			"include": "#dialog"
		},
		{
			"include": "#background"
		},
		{
			"include": "#music"
		},
		{
			"include": "#fade"
		},
		{
			"include": "#valuechange"
		},
		{
			"include": "#standing"
		},
		{
			"include": "#choice"
		},
		{
			"include": "#ending"
		},
		{
			"include": "#specialflag"
		},
		{
			"include": "#end"
		}
	],
	"repository": {
		"variables": {
			"patterns": [
				{
					"name": "variable.other.rikunovel",
					"match": "\\{\\$[a-zA-Z0-9_]+\\}"
				}
			]
		},
		"dialog": {
			"patterns": [
				{
					"match": "^([^「]+)(?=「)",
					"captures": {
						"1": {
							"name": "entity.name.type"
						}
					}
				},
				{
					"begin": "「",
					"end": "」",
					"name": "string.quoted.double"
				}
			]
		},
		"background": {
			"patterns": [
				{
					"match": "<(背景):([^>]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "constant.numeric"
						}
					}
				}
			]
		},
		"music": {
			"patterns": [
				{
					"match": "<(音楽):(STOP|REPLAY|PARSE|[^>]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "support.constant"
						}
					}
				}
			]
		},
		"fade": {
			"patterns": [
				{
					"match": "<(フェードイン|フェードアウト):([0-9\\.]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "constant.numeric"
						}
					}
				}
			]
		},
		"valuechange": {
			"patterns": [
				{
					"match": "<(値変化):([^/]+)/(true|false)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "variable.other"
						},
						"3": {
							"name": "constant.language"
						}
					}
				},
				{
					"match": "<(値変化):([^/]+)/(-?[0-9\\.]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "variable.other"
						},
						"3": {
							"name": "constant.numeric"
						}
					}
				}
			]
		},
		"standing": {
			"patterns": [
				{
					"match": "<(立ち絵):(出場|移動|退場|立ち絵変更)/([^/>]+)(?:/([^/>]+))?(?:/([^/>]+))?(?:/([^/>]+))?(?:/([^>]+))?>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "support.function"
						},
						"3": {
							"name": "entity.name.type"
						},
						"4": {
							"name": "support.constant"
						},
						"5": {
							"name": "constant.numeric"
						},
						"6": {
							"name": "constant.numeric"
						},
						"7": {
							"name": "constant.numeric"
						}
					}
				}
			]
		},
		"choice": {
			"patterns": [
				{
					"match": "<(選択肢):([^>]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "string"
						}
					}
				}
			]
		},
		"ending": {
			"patterns": [
				{
					"match": "<(エンド):([^/]+)/([^>]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "support.constant"
						},
						"3": {
							"name": "constant.numeric"
						}
					}
				}
			]
		},
		"specialflag": {
			"patterns": [
				{
					"match": "<(特殊フラグ):([^/]+)/([^>]+)>",
					"captures": {
						"1": {
							"name": "keyword.control"
						},
						"2": {
							"name": "support.constant"
						},
						"3": {
							"name": "constant.numeric"
						}
					}
				}
			]
		},
		"end": {
			"patterns": [
				{
					"match": "^end$",
					"name": "keyword.control"
				}
			]
		}
	}
}