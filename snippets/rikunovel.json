{
    "背景": {
        "prefix": "bg",
        "body": [
            "<背景:${1:1}>"
        ],
        "description": "背景変更"
    },
    "BGM": {
        "prefix": "bgm",
        "body": [
            "<音楽:${1:楽曲名}>"
        ],
        "description": "BGM再生"
    },
    "BGM停止": {
        "prefix": "bgmstop",
        "body": [
            "<音楽:STOP>"
        ],
        "description": "BGM停止"
    },
    "フェードイン": {
        "prefix": "fadein",
        "body": [
            "<フェードイン:${1:1}>"
        ],
        "description": "フェードイン"
    },
    "フェードアウト": {
        "prefix": "fadeout",
        "body": [
            "<フェードアウト:${1:1}>"
        ],
        "description": "フェードアウト"
    },
    "数値変更": {
        "prefix": "set",
        "body": [
            "<値変化:${1:変数名}/${2:1}>"
        ],
        "description": "数値変更"
