{
  "name": "rikunovel",
  "displayName": "RikuNovel",
  "description": "Language support for RikuNovel scripts.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:rikunovel"
  ],
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "rikunovel",
        "aliases": [
          "RikuNovel",
          "rikunovel"
        ],
        "extensions": [
          ".story.txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rikunovel",
        "scopeName": "source.rikunovel",
        "path": "./syntaxes/rikunovel.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "rikunovel",
        "path": "./snippets/rikunovel.json"
      }
    ]
  },
  "dependencies": {
    "vscode": "^1.1.37"
  }
}